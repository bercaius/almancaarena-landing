rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an authenticated administrator (admin/moderator/support)
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email.lower() in ["berkayozdemirtrtr@gmail.com", "berkayozdemirmain@gmail.com", "turcodevelop@gmail.com"] ||
         (exists(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)) &&
          (get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == "admin" ||
           get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == "support" ||
           get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == "moderator")));
    }
    
    // Helper function to check if the user is a super administrator (owner/admin role)
    function isSuperAdmin() {
      return request.auth != null && 
        (request.auth.token.email.lower() in ["berkayozdemirtrtr@gmail.com", "berkayozdemirmain@gmail.com", "turcodevelop@gmail.com"] ||
         (exists(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)) &&
          get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == "admin"));
    }

    // Helper function to check if the user is a sponsor
    function isSponsor() {
      return request.auth != null &&
        (exists(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == "sponsor");
    }

    // 1. system_config rules with document-level security
    match /system_config/maintenance {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system_config/permissions {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system_config/developer_ad {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system_config/sponsor_ad {
      allow read: if true;
      allow write: if isAdmin() || isSponsor();
    }
    
    // Fallback for any other system config document
    match /system_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 2. admin_roles rules
    match /admin_roles/{email} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    
    // 3. feedbacks (Geri bildirimler) rules
    match /feedbacks/{documentId} {
      allow read: if true;
      allow create: if request.resource.data.userName.size() > 0 && 
                    request.resource.data.comment.size() > 0 && 
                    request.resource.data.comment.size() < 1000 &&
                    request.resource.data.timestamp == request.time;
      allow update, delete: if isAdmin();
    }
    
    // 4. tickets (Destek Talepleri) rules
    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if request.resource.data.ticketId == ticketId &&
                    request.resource.data.createdAt == request.time;
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // 5. banned_users (Banlı Kullanıcılar) rules
    match /banned_users/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. users (Kayıtlı Üyeler) rules
    match /users/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email.lower() == email.lower());
      allow write: if isAdmin() || (request.auth != null && request.auth.token.email.lower() == email.lower());
    }

    // 7. admin_login_logs (Yönetici Giriş Günlüğü) rules
    match /admin_login_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}

